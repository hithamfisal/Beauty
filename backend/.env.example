PORT=4000
NODE_ENV=development

# MySQL / MariaDB only.
# Local development example:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=beauty_home_service
MYSQL_USER=beauty_user
MYSQL_PASSWORD=replace-with-local-mysql-password

# Optional single URL form. If set, it must be mysql://...
# MYSQL_URL=mysql://beauty_user:password@127.0.0.1:3306/beauty_home_service

# Namecheap production usually uses the cPanel-created database/user:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=cpaneluser_beauty
# MYSQL_USER=cpaneluser_beautyuser
# MYSQL_PASSWORD=your-cpanel-mysql-user-password

JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Required in production. Comma-separated, exact browser origins.
CORS_ALLOWED_ORIGINS=https://your-admin-domain.com,https://your-customer-domain.com

# Required for production customer OTP delivery.
OTP_DELIVERY_CHANNEL=auto
SMS_API_URL=https://sms-provider.example/v1/messages
SMS_API_TOKEN=replace-with-provider-token
SMS_SENDER_ID=Beauty

# Optional WhatsApp Cloud API OTP. If configured and OTP_DELIVERY_CHANNEL is
# auto or whatsapp, OTPs are sent with the approved authentication template.
WHATSAPP_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=replace-with-meta-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_OTP_TEMPLATE_NAME=replace-with-approved-auth-template
WHATSAPP_TEMPLATE_LANGUAGE=ar

# Admin login protection.
ADMIN_LOGIN_WINDOW_MINUTES=15
ADMIN_LOGIN_MAX_FAILURES=5

# Optional image upload integration.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
MAX_IMAGE_DATA_URL_BYTES=4194304

# Raw SQL backups are restricted to super_admin only. Company admins should use
# the tenant JSON export endpoint from the dashboard.
BACKUP_DIR=./backups

# SaaS settings
DEFAULT_TENANT_SLUG=beauty-home-service
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-very-strong-super-admin-password
