PORT=4000
DATABASE_URL=postgres://postgres:postgres123@localhost:5432/henna_booking
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
NODE_ENV=development

# Required in production. Comma-separated, exact browser origins.
CORS_ALLOWED_ORIGINS=https://your-admin.vercel.app,https://your-customer-web.vercel.app

# Required for production customer OTP delivery.
SMS_API_URL=https://sms-provider.example/v1/messages
SMS_API_TOKEN=replace-with-provider-token
SMS_SENDER_ID=Beauty

# Optional image upload integration.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Database backup settings
# Used for the local PostgreSQL backup. If omitted, DATABASE_URL will be used.
LOCAL_DATABASE_URL=postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/beauty_db

# Used for Supabase cloud backup. Keep this only in backend/.env, never in React/frontend.
SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_SUPABASE_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Optional if pg_dump is not available in PATH on Windows.
PG_DUMP_PATH=C:\\Program Files\\PostgreSQL\\18\\bin\\pg_dump.exe

# Optional backup output folder. Default: backend/backups
BACKUP_DIR=./backups
